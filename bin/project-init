#!/bin/sh
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"

. "${SCRIPT_DIR}/lib/helpers.sh"
. "${SCRIPT_DIR}/lib/template.sh"
. "${SCRIPT_DIR}/lib/questions.sh"

# Using set -e (not -eu) in entry point because optional vars (PROJECT_DESCRIPTION, TECH_STACK, etc.)
# may be unset in non-interactive mode. lib scripts use set -eu independently.
set -e

# Default values for optional variables (prevents unbound variable issues)
TECH_STACK=""
PROJECT_DESCRIPTION=""
PRESET_PATH=""
PROJECT_TYPES=""

PROJECT_INIT_VERSION="0.1.0"

# --- Defaults ---
MODE="full"     # full, claude-only
PROJECT_TYPE=""
PROJECT_NAME=""
YES_MODE=0

# --- Parse flags ---
while [ $# -gt 0 ]; do
  case "$1" in
    -n|--name) PROJECT_NAME="$2"; shift 2 ;;
    -t|--type) PROJECT_TYPE="$2"; shift 2 ;;
    -p|--preset) PRESET_PATH="$2"; shift 2 ;;
    --types) PROJECT_TYPES="$2"; shift 2 ;;
    -c|--claude-only) MODE="claude-only"; shift ;;
    -y|--yes|--non-interactive) YES_MODE=1; shift ;;
    -v|--version) echo "project-init v${PROJECT_INIT_VERSION}"; exit 0 ;;
    -h|--help)
      cat <<EOF
project-init v${PROJECT_INIT_VERSION}
一键初始化新项目的 .claude/ 目录和 CLAUDE.md

用法: project-init [选项] [项目目录]

选项:
  -n, --name <name>    项目名
  -t, --type <type>    项目类型: cli-tool|web-app|ts-lib|next-app
  -p, --preset <path>  自定义 preset 文件路径
  --types <type,type>  批量初始化 (如 cli-tool,web-app,ts-lib,next-app)
  -c, --claude-only    只生成 CLAUDE.md (已有项目中使用)
  -y, --yes, --non-interactive  非交互模式 (使用所有默认值)
  -v, --version        版本信息
  -h, --help           帮助

项目目录:
  提供时 → 创建该目录并进入
  省略时 → 使用当前目录

示例:
  project-init -n my-app -t cli-tool -y
  project-init my-web-app
  cd my-project && project-init -c
EOF
      exit 0
    ;;
    -*)
      log_error "Unknown flag: $1"
      exit 1
    ;;
    *)
      PROJECT_DIR="$1"
      shift
    ;;
  esac
done

# --- Banner ---
cat << "EOF"
╭─────────────────────────────╮
│  project-init v0.1.0       │
│  一键初始化新项目           │
╰─────────────────────────────╯
EOF

# --- Determine target directory ---
if [ -n "${PROJECT_DIR:-}" ]; then
  mkdir -p "$PROJECT_DIR"
  cd "$PROJECT_DIR"
  log_info "Working in: $(pwd)"
fi

# --- Interactive Q&A (unless -y) ---
if [ "$YES_MODE" -eq 0 ] && [ "$MODE" = "full" ]; then
  PROJECT_NAME=$(ask_project_name "${PROJECT_NAME:-$(basename "$(pwd)")}")
  if [ -z "${PROJECT_TYPES:-}" ]; then
    PROJECT_TYPE=$(ask_project_type)
  fi
  PROJECT_DESCRIPTION=$(ask_description)
  TECH_STACK=$(ask_tech_stack)
  CUSTOM_RULES=$(ask_custom_rules)
else
  PROJECT_NAME="${PROJECT_NAME:-$(basename "$(pwd)")}"
  PROJECT_TYPE="${PROJECT_TYPE:-cli-tool}"
fi

# --- Validate flags ---
# Validate --preset path if provided
if [ -n "${PRESET_PATH:-}" ] && [ ! -f "$PRESET_PATH" ]; then
  log_error "Preset file not found: $PRESET_PATH"
  exit 1
fi

# --types is mutually exclusive with -t and --preset
if [ -n "${PROJECT_TYPES:-}" ]; then
  if [ -n "$PROJECT_TYPE" ]; then
    log_error "Cannot use both --type (-t) and --types"
    exit 1
  fi
  if [ -n "${PRESET_PATH:-}" ]; then
    log_error "Cannot use both --preset and --types"
    exit 1
  fi
fi

# --- .claude/ directory (always created, idempotent) ---
mkdir -p .claude/rules

# Write settings.json only if it doesn't exist yet (claude-only mode)
# or always (full mode overwrites to ensure fresh config)
if [ "$MODE" = "claude-only" ]; then
  if [ ! -f ".claude/settings.json" ]; then
    cat > .claude/settings.json << 'SETTINGS'
{
  "permissions": {
    "allow": [],
    "deny": []
  }
}
SETTINGS
    log_success ".claude/settings.json created"
  else
    log_info ".claude/settings.json already exists, skipped"
  fi
  log_success ".claude/ directory ready"
else
  cat > .claude/settings.json << 'SETTINGS'
{
  "permissions": {
    "allow": [],
    "deny": []
  }
}
SETTINGS
  log_success ".claude/settings.json created"
  log_success ".claude/ directory created"
fi

# --- Full mode: git init + .gitignore ---
if [ "$MODE" = "full" ]; then
  check_dependencies git envsubst

  if [ -d ".git" ]; then
    log_info "Git already initialized"
  else
    git init > /dev/null 2>&1
    log_success "git init"
  fi

  # Write .gitignore if not exists
  if [ ! -f ".gitignore" ]; then
    cat > .gitignore << 'GITIGNORE'
.DS_Store
*.swp
*.swo
*~
.vscode/
.idea/
*.tmp
GITIGNORE
    log_success ".gitignore created"
  fi
fi

# --- Generate CLAUDE.md ---
UNIVERSAL_TEMPLATE="${SCRIPT_DIR}/templates/universal.md"

if [ -n "${PROJECT_TYPES:-}" ]; then
  # --- Multi-type mode: one CLAUDE-<type>.md per type ---
  OLD_IFS="$IFS"
  IFS=","
  for t in $PROJECT_TYPES; do
    # Load preset
    pt_preset="${SCRIPT_DIR}/templates/presets/${t}.md"
    pt_content=""
    if [ -f "$pt_preset" ]; then
      pt_content=$(cat "$pt_preset")
    fi

    # Template vars for this type
    LANGUAGE=""; FRAMEWORK=""; TEST_FRAMEWORK=""; RUNTIME=""
    SHEBANG=""; MODULE_BOUNDARIES=""; UI_FRAMEWORK=""; STATE_MANAGEMENT=""; MOCK_TOOL=""
    case "$t" in
      cli-tool)
        LANGUAGE="${TECH_STACK%%,*}"
        TEST_FRAMEWORK="$(echo "${TECH_STACK}" | grep -E 'pytest|bats|go test|cargo test|jest' | head -1 || echo 'standard')"
        SHEBANG="bash"
        MODULE_BOUNDARIES="(由项目自定义)"
        ;;
      web-app)
        LANGUAGE="JavaScript/TypeScript"
        FRAMEWORK="${TECH_STACK}"
        TEST_FRAMEWORK="jest/vitest"
        RUNTIME="Node.js"
        UI_FRAMEWORK="${TECH_STACK}"
        STATE_MANAGEMENT="(由项目自定义)"
        MOCK_TOOL="vitest mocks / MSW"
        MODULE_BOUNDARIES="(由项目自定义)"
        ;;
      ts-lib)
        LANGUAGE="TypeScript"
        TEST_FRAMEWORK="vitest"
        RUNTIME="Node.js"
        MODULE_BOUNDARIES="src/ — 源码
test/ — 测试文件
公开 API 通过 src/index.ts re-export"
        ;;
      next-app)
        LANGUAGE="TypeScript"
        TEST_FRAMEWORK="vitest/playwright"
        RUNTIME="Node.js"
        FRAMEWORK="Next.js (App Router)"
        UI_FRAMEWORK="Next.js (App Router)"
        MODULE_BOUNDARIES="app/ — Next.js App Router 页面和 API
components/ — 可复用 React 组件
lib/ — 工具函数和 API 客户端
types/ — TypeScript 类型定义"
        ;;
      *)
        log_error "Unknown project type: $t"
        exit 1
        ;;
    esac

    render_template "$UNIVERSAL_TEMPLATE" "$(pwd)/CLAUDE-${t}.md" \
      "PROJECT_NAME=${PROJECT_NAME}" \
      "PROJECT_DESCRIPTION=${PROJECT_DESCRIPTION:-}" \
      "LANGUAGE=${LANGUAGE}" \
      "FRAMEWORK=${FRAMEWORK}" \
      "TEST_FRAMEWORK=${TEST_FRAMEWORK}" \
      "RUNTIME=${RUNTIME}" \
      "PRESET_CONTENT=${pt_content}" \
      "SHEBANG=${SHEBANG}" \
      "MODULE_BOUNDARIES=${MODULE_BOUNDARIES}" \
      "UI_FRAMEWORK=${UI_FRAMEWORK}" \
      "STATE_MANAGEMENT=${STATE_MANAGEMENT}" \
      "MOCK_TOOL=${MOCK_TOOL}"
  done
  IFS="$OLD_IFS"
else
  # --- Single-type mode ---
  # Set template vars
  case "$PROJECT_TYPE" in
    cli-tool|web-app|ts-lib|next-app)
      PRESET_FILE="${SCRIPT_DIR}/templates/presets/${PROJECT_TYPE}.md"
      ;;
    *)
      log_error "Unknown project type: $PROJECT_TYPE"
      exit 1
      ;;
  esac

  # If --preset was given, override the preset file
  if [ -n "${PRESET_PATH:-}" ]; then
    PRESET_FILE="$PRESET_PATH"
  fi

  # Load preset content
  PRESET_CONTENT=""
  if [ -f "$PRESET_FILE" ]; then
    PRESET_CONTENT=$(cat "$PRESET_FILE")
  fi

  # Parse tech stack into components
  LANGUAGE=""; FRAMEWORK=""; TEST_FRAMEWORK=""; RUNTIME=""
  SHEBANG=""; MODULE_BOUNDARIES=""; UI_FRAMEWORK=""; STATE_MANAGEMENT=""; MOCK_TOOL=""
  case "$PROJECT_TYPE" in
    cli-tool)
      LANGUAGE="${TECH_STACK%%,*}"
      TEST_FRAMEWORK="$(echo "${TECH_STACK}" | grep -E 'pytest|bats|go test|cargo test|jest' | head -1 || echo 'standard')"
      SHEBANG="bash"
      MODULE_BOUNDARIES="(由项目自定义)"
      ;;
    web-app)
      LANGUAGE="JavaScript/TypeScript"
      FRAMEWORK="${TECH_STACK}"
      TEST_FRAMEWORK="jest/vitest"
      RUNTIME="Node.js"
      UI_FRAMEWORK="${TECH_STACK}"
      STATE_MANAGEMENT="(由项目自定义)"
      MOCK_TOOL="vitest mocks / MSW"
      MODULE_BOUNDARIES="(由项目自定义)"
      ;;
    ts-lib)
      LANGUAGE="TypeScript"
      TEST_FRAMEWORK="vitest"
      RUNTIME="Node.js"
      MODULE_BOUNDARIES="src/ — 源码
test/ — 测试文件
公开 API 通过 src/index.ts re-export"
      ;;
    next-app)
      LANGUAGE="TypeScript"
      TEST_FRAMEWORK="vitest/playwright"
      RUNTIME="Node.js"
      FRAMEWORK="Next.js (App Router)"
      UI_FRAMEWORK="Next.js (App Router)"
      MODULE_BOUNDARIES="app/ — Next.js App Router 页面和 API
components/ — 可复用 React 组件
lib/ — 工具函数和 API 客户端
types/ — TypeScript 类型定义"
      ;;
  esac

  render_template "$UNIVERSAL_TEMPLATE" "$(pwd)/CLAUDE.md" \
    "PROJECT_NAME=${PROJECT_NAME}" \
    "PROJECT_DESCRIPTION=${PROJECT_DESCRIPTION:-}" \
    "LANGUAGE=${LANGUAGE}" \
    "FRAMEWORK=${FRAMEWORK}" \
    "TEST_FRAMEWORK=${TEST_FRAMEWORK}" \
    "RUNTIME=${RUNTIME}" \
    "PRESET_CONTENT=${PRESET_CONTENT}" \
    "SHEBANG=${SHEBANG}" \
    "MODULE_BOUNDARIES=${MODULE_BOUNDARIES}" \
    "UI_FRAMEWORK=${UI_FRAMEWORK}" \
    "STATE_MANAGEMENT=${STATE_MANAGEMENT}" \
    "MOCK_TOOL=${MOCK_TOOL}"

  log_success "CLAUDE.md generated"
fi

# --- Initial commit (full mode) ---
if [ "$MODE" = "full" ]; then
  git add -A > /dev/null 2>&1
  git commit -m "chore: initialize project with project-init" > /dev/null 2>&1 || true
  log_success "Initial commit created"
fi

# --- Summary ---
echo ""
log_success "Done! Project initialized at $(pwd)"
echo ""
echo "  ${CYAN}Next steps:${NC}"
echo "  1. Edit CLAUDE.md to refine project-specific rules"
echo "  2. Start coding: claude"
echo ""
